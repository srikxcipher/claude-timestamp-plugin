#!/usr/bin/env bash
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
LOG_FILE="${HOME}/.claude/timestamp-audit.log"

echo "⏱  [${TIMESTAMP}] Claude response completed" > /dev/tty 2>/dev/null || true
mkdir -p "$(dirname "$LOG_FILE")"
echo "[${TIMESTAMP}] Claude response completed" >> "$LOG_FILE" 2>/dev/null || true

printf '{}\n'
exit 0
